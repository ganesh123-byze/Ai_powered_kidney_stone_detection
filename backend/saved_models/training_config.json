{
  "data_dir": "./data",
  "output_dir": "./saved_models",
  "model": "resnet50",
  "pretrained": true,
  "freeze_backbone": false,
  "epochs": 30,
  "batch_size": 8,
  "accumulation_steps": 4,
  "lr": 0.0003,
  "weight_decay": 0.0001,
  "val_split": 0.15,
  "test_split": 0.15,
  "mixed_precision": false,
  "num_workers": 0,
  "grad_clip": 1.0,
  "patience": 7,
  "augmentation": "light",
  "seed": 42,
  "use_clahe": false,
  "scheduler": "onecycle",
  "num_classes": 2,
  "class_names": [
    "Normal",
    "stone"
  ]
}