# ============================================================================
# Kidney Stone Detection Backend - Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values
# DO NOT commit .env to repository - it contains sensitive information

# ============================================================================
# API Configuration
# ============================================================================
# API host and port
API_HOST=0.0.0.0
API_PORT=8000

# CORS Origins - comma-separated for multiple origins
# Development
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# Production (Render)
# CORS_ORIGINS=https://kidney-detection-frontend.onrender.com,https://yourdomain.com

# NOTE: For Render deployment, set CORS_ORIGINS in:
# Render Dashboard → Your Backend Service → Environment

# ============================================================================
# Model Configuration
# ============================================================================
# Model architecture: resnet50 or densenet121
MODEL_ARCHITECTURE=resnet50

# Path to model checkpoint
# Local: saved_models/best_model.pth
# Render: Automatically downloaded from GitHub Releases during build
MODEL_PATH=saved_models/best_model.pth

# Model name (for logging)
MODEL_NAME=kidney_stone_detector

# Device: cuda, cpu, or auto
# Note: Free Render tier doesn't support GPU, use 'cpu'
DEVICE=cpu

# Use mixed precision for inference (faster but slightly less accurate)
USE_AMP=true

# ============================================================================
# Inference Configuration
# ============================================================================
# Maximum image size for processing (pixels)
MAX_IMAGE_SIZE=512

# Supported image formats (comma-separated)
SUPPORTED_FORMATS=jpg,jpeg,png,bmp

# Batch size for batch predictions
INFERENCE_BATCH_SIZE=4

# ============================================================================
# Logging Configuration
# ============================================================================
# Log level: TRACE, DEBUG, INFO, SUCCESS, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log file rotation size (e.g., 10 MB)
LOG_ROTATION=10 MB

# Log retention days
LOG_RETENTION=7

# ============================================================================
# Storage Configuration (for Render persistent storage)
# ============================================================================
# Upload directory for temporary files
UPLOAD_DIR=data/uploads

# Cleanup interval (minutes) - remove old uploads
CLEANUP_INTERVAL=60

# ============================================================================
# Performance Tuning
# ============================================================================
# Recommended: 1-2 for Render free tier, 2-4 for paid tiers
NUM_WORKERS=1

# Cache inference results (in-memory)
ENABLE_CACHE=true

# Cache TTL in seconds
CACHE_TTL=3600

# ============================================================================
# Render & Cloud Deployment
# ============================================================================
# Automatically set on Render, but can be overridden for testing
# - Render detects this automatically
RENDER=false

# Model download URL (for Render builds)
# Update this ONLY after uploading model to GitHub Releases
# MODEL_DOWNLOAD_URL=https://github.com/ganesh123-byze/Ai_powered_kidney_stone_detection/releases/download/v1.0.0/best_model.pthg (requests per minute)
RATE_LIMIT=100
