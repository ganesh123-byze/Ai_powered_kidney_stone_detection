# ============================================================================
# Kidney Stone Detection Frontend - Environment Variables
# ============================================================================
# Copy this file to .env.local and fill in the values
# DO NOT commit .env.local to repository

# ============================================================================
# API Configuration
# ============================================================================
# Backend API URL
# Local development
VITE_API_URL=http://localhost:8000

# Production - use your deployed backend URL on Render
# VITE_API_URL=https://kidney-detection-backend.onrender.com

# ============================================================================
# Application Configuration
# ============================================================================
# App environment: development, staging, or production
VITE_ENVIRONMENT=development

# ============================================================================
# Debug & Logging
# ============================================================================
# Enable debug logging in console
VITE_DEBUG=true

# ============================================================================
# Feature Flags
# ============================================================================
# Enable batch processing
VITE_ENABLE_BATCH_PROCESSING=true

# Enable model selection dropdown
VITE_ENABLE_MODEL_SELECTION=true

# ============================================================================
# UI Configuration
# ============================================================================
# App title
VITE_APP_TITLE=Kidney Stone Detection

# ============================================================================
# Analytics (Optional)
# ============================================================================
# Google Analytics ID (optional)
# VITE_GA_ID=UA-XXXXXXXXX-X
